# Pi reads API keys from your shell environment. Copy to .env and fill in,
# then `source .env` before launching pi (or use the just recipes, which
# auto-load .env via `set dotenv-load`).

# OpenAI        — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic     — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google        — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenRouter    — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- pi-coms tuning (all optional) ----------------------------------------
# PI_COMS_MAX_HOPS=5
# PI_COMS_TIMEOUT_MS=1800000
# PI_COMS_INLINE_LIMIT=6000
# PI_COMS_NET_MAX_HOPS=5
# PI_COMS_NET_TIMEOUT_MS=1800000
# PI_COMS_NET_INLINE_LIMIT=6000
