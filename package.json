{
  "name": "pi-coms",
  "version": "0.1.0",
  "description": "Agent-to-agent communication for the Pi coding agent: flat peer-to-peer (coms) and hub-and-spoke (coms-net), local-first over Unix sockets.",
  "license": "MIT",
  "type": "module",
  "files": [
    "extensions",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions/coms.ts",
      "./extensions/coms-net.ts"
    ]
  },
  "scripts": {
    "hub": "bun scripts/coms-net-hub.ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "^0.73.1"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "0.73.1",
    "@mariozechner/pi-coding-agent": "0.73.1",
    "@sinclair/typebox": "0.34.49",
    "@types/node": "25.9.1",
    "typescript": "6.0.3"
  }
}
